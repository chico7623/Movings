:{$PORT:8080} {
    encode gzip zstd

    # Same-origin API proxy for the PHP backend.
    # This avoids browser CORS issues and avoids relying on Vite build-time env injection.
    handle_path /api/php/* {
        reverse_proxy {$PHP_API_URL:https://movings-production.up.railway.app}
    }

    # React Router/Vite SPA: permite refresh em /admin, /watchlist, etc.
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }
}
